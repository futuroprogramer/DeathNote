<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Death Note</title>

<style>
body {
  background: black;
  color: white;
  text-align: center;
  font-family: Arial;
}

input, button {
  padding: 10px;
  font-size: 16px;
}

.lista {
  margin-top: 20px;
  color: red;
}
</style>
</head>

<body>

<h1>DEATH NOTE</h1>

<input type="text" id="nome" placeholder="Digite um nome">
<button onclick="escrever()">Escrever</button>

<div class="lista" id="lista"></div>

<script>
// carregar nomes salvos
let nomes = JSON.parse(localStorage.getItem("nomes")) || [];

// mostrar na tela
function mostrarLista() {
  document.getElementById("lista").innerHTML = nomes.join("<br>");
}

// adicionar nome
function escrever() {
  let nome = document.getElementById("nome").value;

  if (nome === "") return;

  nomes.push(nome);

  // salvar no navegador
  localStorage.setItem("nomes", JSON.stringify(nomes));

  mostrarLista();
}

// carregar quando abrir o site
mostrarLista();
</script>

</body>
</html>
